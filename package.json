{
  "name": "bcrrs",
  "version": "1.0.0",
  "description": "Blockchain-based Contractor Reputation and Ranking System (BCRRS) — Smart contract implementation for the paper: 'A Blockchain-Based Dynamic Contractor Reputation and Ranking System with Machine Learning for Transparent Construction Procurement'",
  "main": "index.js",
  "scripts": {
    "compile":   "npx hardhat compile",
    "test":      "npx hardhat test",
    "gas":       "REPORT_GAS=true npx hardhat test",
    "deploy:local":  "npx hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network sepolia",
    "coverage":  "npx hardhat coverage",
    "clean":     "npx hardhat clean"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "solidity",
    "construction",
    "contractor",
    "reputation",
    "procurement",
    "ethereum",
    "hardhat"
  ],
  "author": "Mujahid Ullah Khan Afridi <mujahida@nmsu.edu>",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.0"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "ethers": "^6.13.0"
  }
}
